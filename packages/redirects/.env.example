# ── Source (used by: export) ──────────────────────────────────────────────────
SOURCE_ADMIN_GQL_URL=https://xxx.cloudfront.net/graphql
SOURCE_API_KEY=your-source-api-key
SOURCE_TENANT=root

# ── Target (used by: import) ──────────────────────────────────────────────────
TARGET_ADMIN_GQL_URL=https://yyy.cloudfront.net/graphql
TARGET_API_KEY=your-target-api-key
TARGET_TENANT=root

# ── Shared options ────────────────────────────────────────────────────────────
LOCALE=en-US

# Import options
CONCURRENCY=5
DRY_RUN=false

# ── Rate limiting & debug ─────────────────────────────────────────────────────
RATE_LIMIT_DELAY_MS=0
DEBUG=false

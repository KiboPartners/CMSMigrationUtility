# ── Source (used by: export) ──────────────────────────────────────────────────
SOURCE_ADMIN_GQL_URL=https://xxx.cloudfront.net/graphql
SOURCE_API_KEY=your-source-api-key
SOURCE_TENANT=root
SOURCE_CDN_DOMAIN=xxx.cloudfront.net
SOURCE_S3_BUCKET=cms-source-bucket   # used in manifest output only
SOURCE_S3_PREFIX=files/                 # used in manifest output only

# ── Target (used by: import) ──────────────────────────────────────────────────
TARGET_ADMIN_GQL_URL=https://yyy.cloudfront.net/graphql
TARGET_API_KEY=your-target-api-key
TARGET_TENANT=root
TARGET_CDN_DOMAIN=yyy.cloudfront.net
TARGET_S3_BUCKET=cms-target-bucket   # used in manifest output only

# ── Shared options ────────────────────────────────────────────────────────────
LOCALE=en-US

# Export options
TAGS_FILTER=           # only export files with these tags (comma-sep); leave empty for all

# Import options
CONCURRENCY=10
DRY_RUN=false
SKIP_EXISTING=true     # skip files already registered in target

# ── Rate limiting & debug ─────────────────────────────────────────────────────
RATE_LIMIT_DELAY_MS=0
DEBUG=false

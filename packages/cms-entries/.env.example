# ── Source (used by: export) ──────────────────────────────────────────────────
SOURCE_ADMIN_GQL_URL=https://xxx.cloudfront.net/graphql
# Manage API — used to read/write content entries
SOURCE_MANAGE_URL=https://xxx.cloudfront.net/cms/manage/en-US
SOURCE_API_KEY=your-source-api-key
SOURCE_TENANT=root
SOURCE_CDN_DOMAIN=xxx.cloudfront.net

# ── Target (used by: import) ──────────────────────────────────────────────────
TARGET_ADMIN_GQL_URL=https://yyy.cloudfront.net/graphql
TARGET_MANAGE_URL=https://yyy.cloudfront.net/cms/manage/en-US
TARGET_API_KEY=your-target-api-key
TARGET_TENANT=root
TARGET_CDN_DOMAIN=yyy.cloudfront.net

# ── Shared options ────────────────────────────────────────────────────────────
LOCALE=en-US

# Export options
# Recommended: export the model schema from Kibo CMS UI (Content Models → ⋮ → Export)
# and point SCHEMA_FILE at it. Model names are read from the file automatically.
SCHEMA_FILE=./cms-schema.json
# If not using a schema file, list model names explicitly (do NOT use ALL)
# MODELS=PromoBanner,Article,Author
SITE_ID_FILTER=

# Import options
CONCURRENCY=5
DRY_RUN=false

# ── Rate limiting & debug ─────────────────────────────────────────────────────
# Milliseconds to sleep after each GraphQL request. Increase (e.g. 200) if you
# hit API rate limits or see "too many requests" errors. Default: 0 (disabled).
RATE_LIMIT_DELAY_MS=0
# Set to "true" to log every GraphQL operation name, variables (truncated),
# response (truncated), and timing. Useful for debugging schema mismatches.
DEBUG=false

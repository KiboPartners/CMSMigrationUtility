{
  "name": "kibo-cms-clone-tool",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "rm -rf packages/*/dist shared/dist",
    "test": "vitest run",
    "export-all": "ts-node index.ts export-all",
    "import-all": "ts-node index.ts import-all"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8"
  }
}

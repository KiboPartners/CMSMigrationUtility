# ─────────────────────────────────────────────────────────────────────────────
# Consolidated configuration for the Kibo CMS migration tool.
#
# Copy to `.env` at the repo root. ALL packages read this single file (resolved
# by walking up to the workspace root). A per-package .env is still honoured as a
# fallback for any var not set here, but the root .env is the canonical place.
# ─────────────────────────────────────────────────────────────────────────────

# ── Source environment (used by: export) ─────────────────────────────────────
SOURCE_ADMIN_GQL_URL=https://cms-api.<region>.<cloud>.kibocommerce.com/graphql
# Manage API — entry CRUD + content-model management (cms-entries only)
SOURCE_MANAGE_URL=https://cms-api.<region>.<cloud>.kibocommerce.com/cms/manage/en-US
SOURCE_API_KEY=your-source-api-key
SOURCE_TENANT=XXXXXX
SOURCE_CDN_DOMAIN=https://cms-api.<region>.<cloud>.kibocommerce.com

# ── Target environment (used by: import) ─────────────────────────────────────
TARGET_ADMIN_GQL_URL=https://cms-api.<region>.<cloud>.kibocommerce.com/graphql
TARGET_MANAGE_URL=https://cms-api.<region>.<cloud>.kibocommerce.com/cms/manage/en-US
TARGET_API_KEY=your-target-api-key
TARGET_TENANT=XXXXXXXX
TARGET_CDN_DOMAIN=https://cms-api.<region>.<cloud>.kibocommerce.com

# ── Shared options ────────────────────────────────────────────────────────────
LOCALE=en-US

# Content models are fetched live from the source API — no export needed.
# Optional: pin an offline model schema (Content Models → ⋮ → Export) instead:
# SCHEMA_FILE=./cms-schema.json
# Optional: restrict cms-entries to specific model names (else all are introspected):
# MODELS=PromoBanner,Article
# Optional: only export cms-entries whose siteId matches:
SITE_ID_FILTER=

# Import options
CONCURRENCY=5                   # parallel writes on import
EXPORT_CONCURRENCY=6            # parallel models during export + catalog listing (falls back to CONCURRENCY)
DRY_RUN=false
SKIP_EXISTING=true              # file-manager: skip files already registered on target
INCLUDE_UNPUBLISHED=true        # page-builder: include unpublished pages on export
TAGS_FILTER=                    # file-manager: only export files with these tags (comma-separated)

# ── file-manager S3 (binaries copied externally; metadata + manifest only) ────
SOURCE_S3_BUCKET=source-bucket
TARGET_S3_BUCKET=target-bucket
SOURCE_S3_PREFIX=files/

# ── Rate limiting & debug ─────────────────────────────────────────────────────
# Milliseconds to sleep after each GraphQL request. Raise (e.g. 200) on rate limits.
RATE_LIMIT_DELAY_MS=0
# "true" logs every GraphQL op name, variables/response (truncated), and timing.
DEBUG=false
